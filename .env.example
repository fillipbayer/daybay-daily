# =====================================================
# DayBay Daily — Configuração de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# =====================================================

# --- OpenAI (OBRIGATÓRIO) ---
# Gera resumos, palavras do dia e áudio TTS
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Voz do boletim em áudio (opções: alloy, echo, fable, onyx, nova, shimmer)
OPENAI_TTS_VOICE=nova

# Modelo para resumos (gpt-4o é o melhor, gpt-4o-mini é mais barato)
OPENAI_MODEL=gpt-4o

# --- Microsoft Calendar (OPCIONAL) ---
# Para integrar reuniões e to-dos do Outlook/Teams
# Crie um app em: https://portal.azure.com → Azure AD → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
# Ou use Device Code Flow (mais simples): deixe CLIENT_SECRET vazio

# --- Configurações Gerais ---
# Porta do servidor (padrão: 8000)
PORT=8000

# Horário do boletim matinal (formato HH:MM, fuso local)
MORNING_BULLETIN_TIME=07:00

# Cidade para clima (opcional — para futuras integrações)
CITY=São Paulo

# Idioma preferido do boletim (pt-BR recomendado)
LOCALE=pt-BR
